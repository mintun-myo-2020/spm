# ============================================================
# SPM Backend - Environment Variables Reference
# ============================================================
# Copy this to .env and fill in values for your environment.
# Defaults shown are for local development with docker-compose.
#
# ENVIRONMENTS:
#   local  → use docker-compose, defaults below work as-is
#   dev    → point to shared dev infra, override DB/KC URLs
#   prod   → use managed services (RDS, Cognito/Keycloak), strong passwords
# ============================================================

# --- Application ---
SERVER_PORT=8080                          # HTTP port for the Spring Boot app
SPRING_PROFILES_ACTIVE=dev                # Spring profile: dev | prod

# --- PostgreSQL (application database) ---
POSTGRES_DB=spm                           # Database name (used by docker-compose)
POSTGRES_USER=spm                         # Database user (used by docker-compose)
POSTGRES_PASSWORD=changeme                # Database password (used by docker-compose)
DB_URL=jdbc:postgresql://localhost:5432/spm   # JDBC URL (app connects here)
DB_USERNAME=spm                           # JDBC username
DB_PASSWORD=changeme                      # JDBC password

# --- Keycloak (identity provider) ---
KEYCLOAK_ADMIN=admin                      # Keycloak admin console username
KEYCLOAK_ADMIN_PASSWORD=changeme          # Keycloak admin console password
KC_DB_USERNAME=keycloak                   # Keycloak's own DB username
KC_DB_PASSWORD=changeme                   # Keycloak's own DB password
KEYCLOAK_ISSUER_URI=http://localhost:8180/realms/spm          # JWT issuer URI
KEYCLOAK_JWK_SET_URI=http://localhost:8180/realms/spm/protocol/openid-connect/certs  # JWK set URI
KEYCLOAK_SERVER_URL=http://localhost:8180  # Keycloak base URL (for Admin REST API)
KEYCLOAK_REALM=spm                        # Keycloak realm name
KEYCLOAK_ADMIN_CLIENT_ID=spm-backend      # Confidential client for admin API calls
KEYCLOAK_ADMIN_CLIENT_SECRET=changeme     # Client secret for spm-backend

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173    # Comma-separated allowed origins

# --- Logging ---
LOG_LEVEL=INFO                            # Root log level: DEBUG | INFO | WARN | ERROR

# --- AWS Authentication ---
# The container mounts ~/.aws from your host (read-only).
# Run `aws configure` (or `aws configure --profile myprofile`) on your host.
# Then set the profile name here. Defaults to "default".
AWS_PROFILE=default
# AWS_REGION=us-east-1                    # Override region if different from profile

# --- Test Paper Extraction (LLM) ---
APP_EXTRACTION_TYPE=stub                  # Extraction engine: stub | bedrock | spring-ai
APP_EXTRACTION_BEDROCK_MODEL_ID=amazon.nova-2-lite-v1:0  # Bedrock model ID (when type=bedrock or spring-ai)
APP_EXTRACTION_BEDROCK_MODEL_ADAPTER=nova  # Model adapter: anthropic | nova (only for type=bedrock)
APP_EXTRACTION_BEDROCK_REGION=ap-southeast-1   # AWS region for Bedrock (optional, uses AWS_REGION if unset)
SPRING_AI_BEDROCK_ENABLED=false           # Enable Spring AI Bedrock auto-config (set true when type=spring-ai)

# --- File Storage ---
APP_STORAGE_TYPE=local                    # Storage backend: local | s3
APP_STORAGE_LOCAL_PATH=./uploads          # Local storage path (when type=local)
APP_STORAGE_S3_BUCKET=spm-uploads         # S3 bucket for file uploads (when type=s3)
APP_REPORT_STORAGE_LOCAL_PATH=./report-files  # Local path for generated reports (when type=local)
APP_REPORT_STORAGE_S3_BUCKET=spm-reports  # S3 bucket for reports (when type=s3)

# --- OCR (legacy, kept for reference) ---
APP_OCR_TYPE=tesseract                    # OCR engine: stub | tesseract | textract
APP_OCR_TESSERACT_URL=http://spm-tesseract:8080  # Tesseract server URL
