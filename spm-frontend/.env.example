# ============================================================
# SPM Frontend - Environment Variables Reference
# ============================================================
# Copy this to .env and fill in values for your environment.
#
# ENVIRONMENTS:
#   local  → backend on localhost:8080, Keycloak on localhost:8180
#   dev    → point to shared dev API and Keycloak
#   prod   → point to production API and Keycloak (use HTTPS)
# ============================================================

# Backend API base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Keycloak server URL (no trailing slash, no /realms/...)
VITE_KEYCLOAK_URL=http://localhost:8180

# Keycloak realm name
VITE_KEYCLOAK_REALM=spm

# Keycloak client ID (must match the client configured in Keycloak)
VITE_KEYCLOAK_CLIENT_ID=spm-frontend

# Tenant display name shown in the navbar (defaults to "Eggtive SPM")
VITE_TENANT_NAME=Eggtive SPM
